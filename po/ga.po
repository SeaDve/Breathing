#: data/io.github.seadve.Breathing.desktop.in:2
#: data/io.github.seadve.Breathing.metainfo.xml.in:7
msgid "Breathing"
msgstr "Análú"

#. Translators: These are search terms to find this application. Do NOT translate or localize the semicolons. The list MUST also end with a semicolon.
#: data/io.github.seadve.Breathing.desktop.in:10
msgid "Utility;Breath;Exercise;"
msgstr "Fóntais;Anáil;Cleachtadh;"

#: data/io.github.seadve.Breathing.metainfo.xml.in:8
msgid "Relax and meditate"
msgstr "Scíth a ligean agus machnamh"

#: data/io.github.seadve.Breathing.metainfo.xml.in:10
msgid ""
"Breathing is a simple application that guides your breathing pattern. This "
"pattern is recommended by experts that will help ease your anxiety."
msgstr ""
"Is feidhmchlár simplí é análaithe a threoraíonn do phatrún análaithe. Tá an "
"patrún seo molta ag saineolaithe a chabhróidh leat do imní a mhaolú."

#: data/io.github.seadve.Breathing.metainfo.xml.in:11
msgid "The main features of Breathing includes the following:"
msgstr "Áirítear ar phríomhghnéithe análaithe na nithe seo a leanas:"

#: data/io.github.seadve.Breathing.metainfo.xml.in:13
msgid "🌬️ Guide your breathing."
msgstr "🌬️ Treoraigh d’análú."

#: data/io.github.seadve.Breathing.metainfo.xml.in:14
msgid "🌑 Change to a dark-mode with ease."
msgstr "🌑 Athraigh go mód dorcha gan stró."

#: data/io.github.seadve.Breathing.metainfo.xml.in:15
msgid "📱 Easy-to-use user interface."
msgstr "📱 Comhéadan úsáideora atá éasca le húsáid."

#: data/io.github.seadve.Breathing.metainfo.xml.in:16
msgid "⌨️ User-friendly keyboard shortcuts."
msgstr "⌨️ Aicearraí méarchláir atá éasca le húsáid."

#: data/io.github.seadve.Breathing.metainfo.xml.in:22
msgid "Start screen with a centered Go button"
msgstr "Tosaigh scáileán le cnaipe Téigh dírithe"

#: data/io.github.seadve.Breathing.metainfo.xml.in:26
msgid "On-going breathing guide screen"
msgstr "Scáileán treoraithe análaithe leanúnach"

